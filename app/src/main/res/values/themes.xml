<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ConstructionDiary" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mi_orange</item>
        <item name="colorPrimaryVariant">@color/mi_orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/mi_orange</item>
        <item name="android:statusBarColor">@color/mi_bg</item>
        <item name="android:windowBackground">@color/mi_bg</item>
        <item name="android:navigationBarColor">@color/mi_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="materialButtonStyle">@style/Widget.ConstructionDiary.Button</item>
    </style>

    <!-- 橙色主按钮：白字 + 橙色背景 + 圆角 -->
    <style name="Widget.ConstructionDiary.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/mi_orange</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- 灰色次要按钮 -->
    <style name="Widget.ConstructionDiary.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/mi_text_primary</item>
        <item name="strokeColor">@color/mi_divider</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- 红色危险按钮 -->
    <style name="Widget.ConstructionDiary.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/mi_danger</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
