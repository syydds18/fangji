<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/mi_bg" android:orientation="vertical"
    android:fitsSystemWindows="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center" android:text="‹" android:textSize="24sp"
            android:textColor="@color/mi_text_primary" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="20dp" android:paddingBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/card_bg" android:orientation="vertical"
                android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="建房地址" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etAddress" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="如：XX省XX县XX村"
                    android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="开工日期" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etDate" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="点击选择日期"
                    android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:focusable="false"
                    android:clickable="true" android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="启动资金（元）" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etBudget" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="总预算金额"
                    android:inputType="numberDecimal" android:paddingHorizontal="12dp"
                    android:textSize="15sp" android:textColor="@color/mi_text_primary" />
            </LinearLayout>
            <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="保存" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />
            <Button android:id="@+id/btnCloudSync" android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="8dp" style="@style/Widget.ConstructionDiary.Button.Secondary"
                android:text="☁️ Supabase云同步" android:textColor="@color/mi_text_primary" android:textSize="15sp" />
            <Button android:id="@+id/btnExportImport" android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="8dp" style="@style/Widget.ConstructionDiary.Button.Secondary"
                android:text="📤 数据导入导出" android:textColor="@color/mi_text_primary" android:textSize="15sp" />
            <Button android:id="@+id/btnAbout" android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="8dp" style="@style/Widget.ConstructionDiary.Button.Secondary"
                android:text="ℹ️ 关于房迹" android:textColor="@color/mi_text_primary" android:textSize="15sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="\n房迹 v1.0.0\n记录建房过程中的每一笔花销"
                android:textSize="12sp" android:textColor="@color/mi_text_hint"
                android:gravity="center" android:layout_marginTop="20dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
