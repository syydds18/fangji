<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/mi_bg" android:orientation="vertical"
    android:fitsSystemWindows="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center" android:text="‹" android:textSize="24sp"
            android:textColor="@color/mi_text_primary" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="20dp" android:paddingBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="姓名 *" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
            <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_input_field" android:hint="工人姓名"
                android:paddingHorizontal="12dp" android:textSize="15sp"
                android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="手机号" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
            <EditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_input_field" android:hint="联系电话"
                android:inputType="phone" android:paddingHorizontal="12dp" android:textSize="15sp"
                android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="工种" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
            <EditText android:id="@+id/etRole" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_input_field" android:hint="泥工/木工/水电/油漆等"
                android:paddingHorizontal="12dp" android:textSize="15sp"
                android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="日薪" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
            <EditText android:id="@+id/etWage" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_input_field" android:hint="每天工资"
                android:inputType="numberDecimal" android:paddingHorizontal="12dp" android:textSize="15sp"
                android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="备注" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
            <EditText android:id="@+id/etNote" android:layout_width="match_parent" android:layout_height="80dp"
                android:background="@drawable/bg_input_field" android:hint="备注"
                android:paddingHorizontal="12dp" android:paddingVertical="10dp"
                android:textSize="15sp" android:textColor="@color/mi_text_primary" android:gravity="top" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="删除"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    style="@style/Widget.ConstructionDiary.Button.Danger"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />
                <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="保存" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
