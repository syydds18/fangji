<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/mi_bg" android:orientation="vertical"
    android:fitsSystemWindows="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center" android:text="‹" android:textSize="24sp"
            android:textColor="@color/mi_text_primary" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="20dp" android:paddingBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/card_bg" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="文档名称 *" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="如：房产证"
                    android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="证件类别" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <Spinner android:id="@+id/spinnerCategory" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="存放位置 *" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etStorageLocation" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="如：书房抽屉第二层"
                    android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="相关方" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etRelatedParty" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="如：开发商/物业/银行"
                    android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="签发日期" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <TextView android:id="@+id/tvIssueDate" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="点击选择日期"
                    android:gravity="center_vertical" android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp"
                    android:clickable="true" android:focusable="true" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="到期日期（可选）" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <TextView android:id="@+id/tvExpireDate" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:hint="点击选择日期"
                    android:gravity="center_vertical" android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp"
                    android:clickable="true" android:focusable="true" />

                <!-- Image Section -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="照片" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <LinearLayout android:id="@+id/layoutImages" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bg_input_field"
                    android:padding="16dp" android:layout_marginBottom="16dp"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/ivImage" android:layout_width="160dp"
                        android:layout_height="160dp" android:scaleType="fitCenter"
                        android:visibility="gone" />
                    <TextView android:id="@+id/tvImageHint" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="📷 点击上传照片"
                        android:textSize="14sp" android:textColor="@color/mi_text_hint" />
                </LinearLayout>
                <TextView android:id="@+id/btnRemoveImage" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="✕ 移除照片"
                    android:textSize="13sp" android:textColor="@color/mi_danger"
                    android:layout_marginBottom="16dp" android:visibility="gone" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="备注" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etNote" android:layout_width="match_parent" android:layout_height="80dp"
                    android:background="@drawable/bg_input_field" android:hint="补充说明"
                    android:paddingHorizontal="12dp" android:paddingVertical="10dp"
                    android:textSize="15sp" android:textColor="@color/mi_text_primary" android:gravity="top" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="删除"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    style="@style/Widget.ConstructionDiary.Button.Danger"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />
                <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="保存" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
