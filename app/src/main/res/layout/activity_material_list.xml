<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="‹"
            android:textSize="24sp"
            android:textColor="@color/mi_text_primary"
            android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 材料清单"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>

    <!-- Summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp">
        <TextView android:id="@+id/tvBudgetTotal"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="13sp"
            android:textColor="@color/mi_text_secondary" />
        <TextView android:id="@+id/tvActualTotal"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/mi_orange"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/chipAll"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:text="全部" android:textSize="13sp"
                android:background="@drawable/bg_chip_selected"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/chipPending"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:text="待购" android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:textColor="@color/mi_text_primary"
                android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/chipBought"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:text="已购" android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:textColor="@color/mi_text_primary"
                android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/chipReceived"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:text="已到货" android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:textColor="@color/mi_text_primary" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            android:clipToPadding="false">
            <LinearLayout
                android:id="@+id/container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="📦 暂无材料记录\n点击右下角添加"
            android:textSize="14sp"
            android:textColor="@color/mi_text_hint"
            android:visibility="gone" />
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="20dp"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="@color/mi_orange"
            app:tint="@color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </FrameLayout>
</LinearLayout>
