<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/mi_bg" android:orientation="vertical"
    android:fitsSystemWindows="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center" android:text="‹" android:textSize="24sp"
            android:textColor="@color/mi_text_primary" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="20dp" android:paddingBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/card_bg" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="日期" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <TextView android:id="@+id/tvDate" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:gravity="center_vertical"
                    android:paddingHorizontal="12dp" android:textSize="15sp"
                    android:textColor="@color/mi_orange" android:clickable="true"
                    android:focusable="true" android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="施工阶段" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <Spinner android:id="@+id/spinnerPhase" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="施工内容 *" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etContent" android:layout_width="match_parent"
                    android:layout_height="100dp" android:background="@drawable/bg_input_field"
                    android:hint="今天做了什么..." android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp" android:textSize="15sp"
                    android:textColor="@color/mi_text_primary" android:gravity="top"
                    android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="天气" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etWeather" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input_field"
                    android:hint="晴/多云/雨" android:paddingHorizontal="12dp"
                    android:textSize="15sp" android:textColor="@color/mi_text_primary"
                    android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="到场工人" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etWorkers" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input_field"
                    android:hint="张三、李四" android:paddingHorizontal="12dp"
                    android:textSize="15sp" android:textColor="@color/mi_text_primary"
                    android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="总体进度" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <SeekBar android:id="@+id/seekProgress" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:max="100" android:progress="0" />
                    <TextView android:id="@+id/tvProgressValue" android:layout_width="48dp"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textSize="14sp" android:textColor="@color/mi_orange"
                        android:gravity="center" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="删除"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    style="@style/Widget.ConstructionDiary.Button.Danger"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />
                <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="保存" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
