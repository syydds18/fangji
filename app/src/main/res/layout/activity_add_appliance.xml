<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/mi_bg"
    android:fitsSystemWindows="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center" android:text="‹" android:textSize="24sp"
            android:textColor="@color/mi_text_primary" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="20dp" android:paddingBottom="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/card_bg" android:orientation="vertical"
                android:padding="20dp" android:layout_marginBottom="16dp">
                <!-- 名称 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="名称 *" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="电器名称" android:paddingHorizontal="12dp"
                    android:inputType="text" android:layout_marginBottom="16dp" />
                <!-- 品牌 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="品牌" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etBrand" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="如：格力、美的" android:paddingHorizontal="12dp"
                    android:inputType="text" android:layout_marginBottom="16dp" />
                <!-- 型号 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="型号" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etModel" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="产品型号" android:paddingHorizontal="12dp"
                    android:inputType="text" android:layout_marginBottom="16dp" />
                <!-- 类别 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="类别" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <Spinner android:id="@+id/spinnerCategory" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp" />
                <!-- 购买渠道 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="购买渠道" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <Spinner android:id="@+id/spinnerChannel" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp" />
                <!-- 购买日期 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="购买日期" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <TextView android:id="@+id/tvPurchaseDate" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="点击选择购买日期" android:gravity="center_vertical" android:paddingHorizontal="12dp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
                <!-- 价格 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="价格 (元)" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etPrice" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="0.00" android:paddingHorizontal="12dp"
                    android:inputType="numberDecimal" android:layout_marginBottom="16dp" />
                <!-- 质保年限 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="质保年限 (年)" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etWarrantyYears" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="如：3" android:paddingHorizontal="12dp"
                    android:inputType="number" android:layout_marginBottom="16dp" />
                <!-- 安装日期 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="安装日期" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <TextView android:id="@+id/tvInstallDate" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="点击选择安装日期" android:gravity="center_vertical" android:paddingHorizontal="12dp"
                    android:textColor="@color/mi_text_primary" android:layout_marginBottom="16dp" />
                <!-- 售后电话 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="售后电话" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etAfterSalePhone" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="售后客服电话" android:paddingHorizontal="12dp"
                    android:inputType="phone" android:layout_marginBottom="16dp" />
                <!-- 序列号 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="序列号" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etSerialNumber" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="产品序列号" android:paddingHorizontal="12dp"
                    android:inputType="text" android:layout_marginBottom="16dp" />
                <!-- 备注 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="备注" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <EditText android:id="@+id/etNote" android:layout_width="match_parent" android:layout_height="88dp"
                    android:background="@drawable/bg_input_field" android:textSize="15sp"
                    android:hint="补充信息" android:paddingHorizontal="12dp" android:paddingVertical="10dp"
                    android:inputType="textMultiLine" android:gravity="top" android:layout_marginBottom="16dp" />
                <!-- 图片 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="图片" android:textSize="12sp" android:textColor="@color/mi_text_secondary" />
                <LinearLayout android:id="@+id/layoutImages" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bg_input_field"
                    android:padding="16dp" android:layout_marginBottom="16dp"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/ivImage" android:layout_width="160dp"
                        android:layout_height="160dp" android:scaleType="fitCenter"
                        android:visibility="gone" />
                    <TextView android:id="@+id/tvImageHint" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="📷 点击上传照片"
                        android:textSize="14sp" android:textColor="@color/mi_text_hint" />
                </LinearLayout>
                <TextView android:id="@+id/btnRemoveImage" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="✕ 移除照片"
                    android:textSize="13sp" android:textColor="@color/mi_danger"
                    android:layout_marginBottom="16dp" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp"
        android:background="@color/mi_bg">
        <Button android:id="@+id/btnDelete" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="删除"
            style="@style/Widget.ConstructionDiary.Button.Danger"
            android:layout_marginEnd="8dp" android:visibility="gone" />
        <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="保存"
            android:textSize="16sp" android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
