<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/mi_bg"
    android:fitsSystemWindows="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="‹"
            android:textSize="24sp"
            android:textColor="@color/mi_text_primary"
            android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="添加礼金"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/mi_text_primary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="给钱人姓名"
                android:textSize="12sp"
                android:textColor="@color/mi_text_secondary"
                android:layout_marginTop="16dp" />
            <EditText
                android:id="@+id/etGiverName"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_field"
                android:hint="请输入姓名"
                android:textColor="@color/mi_text_primary"
                android:textColorHint="@color/mi_text_hint"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关系"
                android:textSize="12sp"
                android:textColor="@color/mi_text_secondary"
                android:layout_marginTop="16dp" />
            <EditText
                android:id="@+id/etRelationship"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_field"
                android:hint="如：亲戚、朋友、邻居"
                android:textColor="@color/mi_text_primary"
                android:textColorHint="@color/mi_text_hint"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="金额"
                android:textSize="12sp"
                android:textColor="@color/mi_text_secondary"
                android:layout_marginTop="16dp" />
            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_field"
                android:hint="0.00"
                android:textColor="@color/mi_text_primary"
                android:textColorHint="@color/mi_text_hint"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:inputType="numberDecimal"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="场合"
                android:textSize="12sp"
                android:textColor="@color/mi_text_secondary"
                android:layout_marginTop="16dp" />
            <Spinner
                android:id="@+id/spinnerOccasion"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日期"
                android:textSize="12sp"
                android:textColor="@color/mi_text_secondary"
                android:layout_marginTop="16dp" />
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:textColor="@color/mi_text_primary"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="备注"
                android:textSize="12sp"
                android:textColor="@color/mi_text_secondary"
                android:layout_marginTop="16dp" />
            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_input_field"
                android:hint="选填"
                android:textColor="@color/mi_text_primary"
                android:textColorHint="@color/mi_text_hint"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:textSize="15sp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Buttons pinned at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="@color/mi_bg">
        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="删除"
            android:textSize="16sp"
            android:textStyle="bold"
            style="@style/Widget.ConstructionDiary.Button.Danger"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />
        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="保存"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
